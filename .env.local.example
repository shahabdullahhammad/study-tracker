# Copy this file to `.env.local` and fill in values after `npx convex dev` (Convex prints the URL).
# The CLI may also write CONVEX_DEPLOYMENT here automatically.

# CONVEX_DEPLOYMENT=dev:your-deployment-name

# Match your deployment in the Convex dashboard (this project: artful-penguin-599).
VITE_CONVEX_URL=https://artful-penguin-599.convex.cloud

# Same deployment’s HTTP (.site) URL — required for client debug ingest + OAuth callbacks.
VITE_CONVEX_SITE_URL=https://artful-penguin-599.convex.site

# Convex Dashboard → env: set ALLOW_CLIENT_DEBUG_LOGS=true to store debug lines from the app (debugIngest).

# OAuth: create apps in Google / GitHub / Discord, then set AUTH_* in the Convex Dashboard
# (not in this file). Ordered checklist: GO_LIVE_CHECKLIST.md — long tutorial: OAUTH_SETUP.md
# AUTH_GOOGLE_ID=  AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=  AUTH_GITHUB_SECRET=
# AUTH_DISCORD_ID=  AUTH_DISCORD_SECRET=

# --- Vercel ---
# Environment variables (Production / Preview): set VITE_CONVEX_URL to your Convex URL,
# e.g. https://YOUR_DEPLOYMENT.convex.cloud — same value as local .env.local.
# If the Git repo root is the parent folder, set Vercel "Root Directory" to `study-tracker`.
# Framework preset: Vite; build: npm run build; output: dist (auto-detected).
